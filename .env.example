# News Report Agent — required environment variables.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# --- OpenRouter (LLM: classify + synthesize) ---
# NOTE: OpenRouter may be unreachable from restricted/corporate networks.
# The model id itself is set in pipeline/config.toml, not here — only the key is a secret.
OPENROUTER_API_KEY=

# --- Dedicated mailbox (IMAP ingest) ---
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=

# --- Embeddings provider ---
# OpenRouter also serves an OpenAI-compatible /embeddings endpoint (see config.toml),
# so the same OpenRouter key can be reused here. Set a different key if you point
# [embeddings] at another vendor.
EMBEDDINGS_API_KEY=

# --- Dashboard HTTP basic auth ---
# Used at deploy time to generate web/.htpasswd (never committed).
DASHBOARD_USER=
DASHBOARD_PASSWORD=
